<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Post-splash screen theme. -->
    <style name="Theme.Chevere" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">#0D47A1</item> <!-- Matches the start of our animated gradient -->
        <item name="android:statusBarColor">#0D47A1</item>
        <item name="android:navigationBarColor">#0D47A1</item>
    </style>

    <!-- Splash Screen theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Deep Blue (#0D47A1) matches the top of our custom Robot Splash gradient -->
        <item name="windowSplashScreenBackground">#0D47A1</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Chevere</item>
    </style>
</resources>
