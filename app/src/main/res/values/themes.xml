<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Post-splash screen theme. -->
    <style name="Theme.AiAssistant" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">#0E1513</item>
        <item name="android:statusBarColor">#0E1513</item>
        <item name="android:navigationBarColor">#0E1513</item>
    </style>

    <!-- Splash Screen theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0E1513</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.AiAssistant</item>
    </style>
</resources>