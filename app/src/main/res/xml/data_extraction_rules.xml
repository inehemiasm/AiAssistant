<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude large AI model files and directories from cloud backup -->
        <exclude domain="file" path="." />
        <!-- Re-include small specific config files if any -->
        <include domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Allow model transfer between devices during setup if desired,
             but typically models should be re-downloaded -->
        <exclude domain="file" path="." />
    </device-transfer>
</data-extraction-rules>
