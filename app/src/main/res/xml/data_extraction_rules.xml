<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- By including only sharedpref, other domains like 'file' and 'database' are excluded by default -->
        <include
            domain="sharedpref"
            path="." />
    </cloud-backup>
    <device-transfer>
        <!-- For device transfer, we can also limit it to shared preferences if that's the intent -->
        <include
            domain="sharedpref"
            path="." />
    </device-transfer>
</data-extraction-rules>
