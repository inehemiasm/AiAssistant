    <string name="local_storage_privacy">Almacenamiento local</string>
    <string name="local_storage_privacy_desc">Los modelos descargados y las imagenes generadas se guardan en almacenamiento local controlado por la app. Al borrar la app se eliminan los datos privados de la app.</string>
