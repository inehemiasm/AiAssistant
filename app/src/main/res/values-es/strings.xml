    <string name="offline_processing">Procesamiento sin conexion</string>
    <string name="offline_processing_desc">La inferencia de chat y la generacion de imagenes se ejecutan con modelos locales instalados. La red solo se usa para catalogos, descargas y herramientas web explicitas.</string>
    <string name="release_content_controls">Controles de contenido en release</string>
