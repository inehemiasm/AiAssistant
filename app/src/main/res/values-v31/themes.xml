<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Attributes for API 31+ -->
        <item name="android:windowSplashScreenBackground">#0D47A1</item>
        <!-- Hide the system icon to avoid seeing it before our custom robot animation starts -->
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.AiAssistant</item>
    </style>
</resources>