<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Post-splash screen theme. -->
    <style name="Theme.AiAssistant" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">#0D47A1</item>
        <item name="android:statusBarColor">#0D47A1</item>
        <item name="android:navigationBarColor">#0D47A1</item>
    </style>

    <!-- Splash Screen theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0D47A1</item>
        <!-- Use transparent to hide the system icon and let our Robot be the only one visible -->
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.AiAssistant</item>
    </style>
</resources>